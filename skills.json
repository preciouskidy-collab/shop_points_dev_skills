{
  "metadata": {
    "version": "0.4.0",
    "name": "Shop Points 全栈 Skill 工具集",
    "description": "Shop Points 研发团队全栈 AI 辅助技能工具集（后端 + 前端 + 大禹部署 + E2E）"
  },
  "pipeline": {
    "stages": [
      {
        "id": "fetch-prd",
        "name": "PRD 拉取",
        "blocking": false,
        "artifacts": [
          "request/prd.md"
        ],
        "resources": [
          "feishu-doc-fetcher"
        ],
        "max_retries": 3
      },
      {
        "id": "break-down",
        "name": "需求拆解",
        "blocking": false,
        "artifacts": [
          "request/spec.md",
          "request/tasks.md"
        ],
        "resources": [
          "knowledge-project-atlas"
        ],
        "max_retries": 0
      },
      {
        "id": "scope-eval",
        "name": "范围评估",
        "blocking": false,
        "artifacts": [
          "impact/impact.md"
        ],
        "resources": [
          "knowledge-component-graph-${project}",
          "knowledge-data-layer-${project}"
        ],
        "max_retries": 0
      },
      {
        "id": "tech-design",
        "name": "技术方案",
        "blocking": false,
        "artifacts": [
          "tech-design/tech-design.md"
        ],
        "resources": [
          "knowledge-project-atlas",
          "knowledge-component-graph-${project}",
          "knowledge-data-layer-${project}",
          "knowledge-message-bus-${project}",
          "knowledge-rpc-contracts-${project}",
          "knowledge-service-topology"
        ],
        "max_retries": 0
      },
      {
        "id": "plan-approve",
        "name": "人工审批",
        "blocking": true,
        "artifacts": [],
        "resources": [],
        "max_retries": 0
      },
      {
        "id": "backend-coding",
        "name": "后端编码",
        "blocking": false,
        "artifacts": [],
        "resources": [
          "guardrail-layering-contracts",
          "guardrail-ai-coding-spec",
          "playbook-spring-boot-coding"
        ],
        "max_retries": 3
      },
      {
        "id": "frontend-handoff",
        "name": "前端交接",
        "blocking": false,
        "skip_when": {
          "impact_field": "frontend_scope",
          "equals": "none"
        },
        "artifacts": [
          "handoff/frontend-handoff.md",
          "handoff/api-contract.yaml"
        ],
        "resources": [
          "playbook-frontend-handoff",
          "knowledge-frontend-atlas"
        ],
        "max_retries": 2
      },
      {
        "id": "frontend-coding",
        "name": "前端编码",
        "blocking": false,
        "skip_when": {
          "impact_field": "frontend_scope",
          "equals": "none"
        },
        "artifacts": [],
        "resources": [
          "playbook-frontend-coding",
          "knowledge-frontend-atlas"
        ],
        "max_retries": 3
      },
      {
        "id": "backend-review",
        "name": "后端审查",
        "blocking": false,
        "artifacts": [
          "review/backend_review_v1.md"
        ],
        "resources": [
          "guardrail-layering-contracts",
          "guardrail-build-standards",
          "guardrail-traceability-rules",
          "guardrail-ai-coding-spec",
          "playbook-review-checklist"
        ],
        "max_retries": 2
      },
      {
        "id": "frontend-review",
        "name": "前端审查",
        "blocking": false,
        "skip_when": {
          "impact_field": "frontend_scope",
          "equals": "none"
        },
        "artifacts": [
          "review/frontend_review_v1.md"
        ],
        "resources": [
          "playbook-frontend-review-checklist",
          "knowledge-frontend-atlas"
        ],
        "max_retries": 2
      },
      {
        "id": "backend-test-local",
        "name": "本地验证",
        "blocking": false,
        "artifacts": [
          "tests/backend_test_report.md"
        ],
        "resources": [
          "guardrail-build-standards",
          "playbook-test-authoring"
        ],
        "max_retries": 3
      },
      {
        "id": "deploy-approve",
        "name": "部署前审批",
        "blocking": true,
        "artifacts": [],
        "resources": [],
        "max_retries": 0
      },
      {
        "id": "commit-push",
        "name": "提交推送",
        "blocking": false,
        "artifacts": [
          "deploy/git_push_report.md"
        ],
        "resources": [
          "playbook-commit-push",
          "playbook-git-branch-init"
        ],
        "max_retries": 2
      },
      {
        "id": "dayu-deploy",
        "name": "大禹部署",
        "blocking": false,
        "artifacts": [
          "deploy/dayu_deploy_report.md"
        ],
        "resources": [
          "playbook-dayu-deploy",
          "knowledge-dayu-platform"
        ],
        "max_retries": 3
      },
      {
        "id": "e2e-browser-test",
        "name": "E2E 浏览器自测",
        "blocking": false,
        "skip_when": {
          "impact_field": "frontend_scope",
          "equals": "none"
        },
        "artifacts": [
          "tests/e2e_test_report.md"
        ],
        "resources": [
          "playbook-e2e-browser-test",
          "knowledge-test-env-topology"
        ],
        "max_retries": 3
      },
      {
        "id": "release",
        "name": "发布验证",
        "blocking": false,
        "artifacts": [
          "deploy/verify.md"
        ],
        "resources": [
          "playbook-release-validation"
        ],
        "max_retries": 0
      }
    ]
  },
